{
  "name": "wireguard-config-generator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create wireguard-configs",
    "db:migrate": "wrangler d1 execute wireguard-configs --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute wireguard-configs --remote --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
